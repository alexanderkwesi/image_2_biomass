{
  "name": "image-2-biomass-ml-project",
  "version": "1.0.0",
  "private": true,
  "author": "Alexander Oluwaseun Kwesi",
  "scripts": {
    "vercel-build": "cd front-end && CI=false npm install && CI=false npm run build",
    "start": "cd front-end && npm start",
    "dev": "concurrently \"npm run start:front-end\" \"npm run start-api\" \"npm run python-build\"",
    "start:front-end": "cd front-end && npm start",
    "start-api": "cd backend-services/api_gateway/app && python -m uvicorn main:app --reload --host 0.0.0.0 --port 5000",
    "reset-project": "node ./scripts/reset-project.js",
    "python-build": "cd backend-services && python database_connection/db_connection.py",
    "test": "cd front-end && npm test",
    "eject": "cd front-end && npm run eject"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
